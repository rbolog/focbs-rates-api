{
	// Cloudflare Workers configuration
	"name": "focbs-rates-api",
	"main": "src/index.ts",
	"compatibility_date": "2024-01-01",

	// Environment variables
	"vars": {
		"KEY_PREFIX": "KEY_C_",
	},

	// KV Namespaces
	"kv_namespaces": [
		{
			"binding": "KV_CURRENCIES_RATES",
			"id": "",
			"preview_id": "",
		},
	],

	"placement": {
    "mode": "smart"
  }
}
